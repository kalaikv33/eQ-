	void EXTI0_IRQHANDLER(){ //EXTI0_IRQHANDLER -> interrupt name match to startup file
		if(EXTI->PR&(1<<0)){ // Pending register for External interrupt
			GPIOA->ODR |= (1<<1);
			delay(5);
			GPIOA->BRR = (1<<1);
			delay(5);
		}
	}
	
	void TIM2_IRQHANDLER(){
		if(TIM2->SR&(1<<0)){
			GPIOC->ODR ^= (1<<13);
			TIM2->SR &=~(1<<0);
		}
