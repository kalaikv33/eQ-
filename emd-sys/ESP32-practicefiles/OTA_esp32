#ifndef MY_OTA_H
#define MY_OTA_H

#define ELEGANTOTA_USE_ASYNC 1

#include <WiFi.h>
#include <AsyncTCP.h>
#include <ESPAsyncWebServer.h>
#include <ElegantOTA.h>

// We declare the server here so it's accessible to the functions
// but we use 'extern' if we want to define it in the main file, 
// or just keep it simple as a global in this header.
extern AsyncWebServer server; 

void startOTA() {
  // Root page
  server.on("/", AsyncWebRequestMethod::HTTP_GET, [](AsyncWebServerRequest *request) {
    request->send(200, "text/plain", "ESP32 is running. Use /update for OTA.");
  });

  // Client IP Route
  server.on("/client-ip", AsyncWebRequestMethod::HTTP_GET, [](AsyncWebServerRequest *request) {
    String clientIP = request->client()->remoteIP().toString();
    request->send(200, "text/plain", "Your Device IP is: " + clientIP);
  });

  // Start ElegantOTA with your credentials
  ElegantOTA.begin(&server, "User", "Pass123");
  server.begin();
  
  Serial.println("HTTP server started and OTA ready.");
}

#endif
/******************* .h file =>> END *******************/

/******************* Use it in your main .ino file *******************/

#include <WiFi.h>
#include "myOTA.h" // Include your custom header

const char* ssid = "kv";
const char* password = "SecureIOT";

// Define the server object here
AsyncWebServer server(80);

void setup() {
  Serial.begin(115200);
  
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  
  Serial.println("\nConnected!");
  Serial.println(WiFi.localIP());

  // Call the function from your header file
  startOTA();
}

void loop() {
  // Still need this for ElegantOTA to handle the reset/update logic
  ElegantOTA.loop();
}

